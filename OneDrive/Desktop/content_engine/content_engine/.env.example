# Example environment variables for content_engine
# Rename to .env and fill with your keys

# DeepSeek / OpenRouter API key (or set DEEPSEEK_API_KEY)
DEEPSEEK_API_KEY=

# Hugging Face or other image provider token (optional for public models)
GPT_IMAGE_API_KEY=

# Replicate API token (used for WAN/video predictions)
REPLICATE_API_TOKEN=

# Optional: model identifiers (override defaults in config.py)
TEXT_MODEL=deepseek-chat
GPT_IMAGE_MODEL=black-forest-labs/FLUX.1
RUNWAY_MODEL=owner/wan-model

# Edge TTS voice (optional)
TTS_VOICE=alloy
# Copy this file to .env and fill in your real keys.
# In PowerShell: Copy-Item .env.example .env

# Text generation (tagline, blog, social, critic, script adapter, channel adaptation)
OPENROUTER_API_KEY=your_openrouter_key_here
TEXT_MODEL=openai/gpt-4o-mini

# Image generation (hero image)
# If you use OpenAI directly for images, put your OpenAI key here.
GPT_IMAGE_API_KEY=your_openai_or_compatible_key_here
GPT_IMAGE_MODEL=gpt-image-1

# Video generation (promo video)
RUNWAY_API_KEY=your_runway_key_here
RUNWAY_MODEL=gen4_turbo

# Voiceover / TTS
TTS_API_KEY=your_tts_provider_key_here
TTS_MODEL=tts-1
TTS_VOICE=alloy
